{
    "name": "antimonial/framework",
    "description": "A PHP MVC framework where what you read is what runs.",
    "type": "framework",
    "license": "MIT",
    "version": "0.19.0",
    "keywords": ["php", "framework", "mvc", "query-builder", "minimal"],
    "homepage": "https://github.com/antimonial/framework",
    "authors": [
        {
            "name": "antimonial"
        }
    ],
    "support": {
        "issues": "https://github.com/antimonial/framework/issues",
        "source": "https://github.com/antimonial/framework"
    },
    "autoload": {
        "psr-4": {
            "Antimonial\\": "src/"
        },
        "files": [
            "src/Core/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Antimonial\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=max",
        "lint": "pint --test",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pint": true
        }
    }
}
